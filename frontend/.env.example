# ZoomX Next.js Client-Side Production Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Deployed Django REST API Base URL (e.g. https://zoomx-backend.onrender.com/api)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Deployed Daphne WebSockets Signaling Gateway URL (e.g. wss://zoomx-backend.onrender.com)
# NOTE: Use 'wss://' for production SSL connections, and 'ws://' for local testing
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Google OAuth 2.0 Web Client ID (matched with backend client configuration)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=902405653902-8rik7sfkdv75jip7etd92rg85mqlm2a4.apps.googleusercontent.com
